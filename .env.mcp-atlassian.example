# mcp-atlassian 환경변수 설정
# 이 파일을 .env.mcp-atlassian 으로 복사 후 값을 채우세요.

# ── Jira ──────────────────────────────────
# Cloud: https://yourorg.atlassian.net
JIRA_URL=https://yourorg.atlassian.net

# Cloud: Atlassian 계정 이메일
JIRA_USERNAME=your@email.com

# Cloud: Atlassian API Token (https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=ATATT3x...

# ── Confluence ────────────────────────────
# 보통 Jira와 동일한 URL
CONFLUENCE_URL=https://yourorg.atlassian.net
CONFLUENCE_USERNAME=your@email.com
CONFLUENCE_API_TOKEN=ATATT3x...
