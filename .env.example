# Node.js 서버
FLASK_API_URL=http://localhost:3000
WS_PORT=5001
FRONTEND_PATH=../frontend    # Node.js 서버에서 서빙할 프론트엔드 경로 (기본값: 서버 디렉토리 기준 ../frontend)
SKILLS_DIR=../skills          # 공유 SKILL.md 디렉토리 (기본값: 서버 기준 ../../skills)
USER_SKILLS_DIR=../skills-user  # 사용자별 SKILL.md 디렉토리 (기본값: 서버 기준 ../../skills-user)

# Flask
VLLM_BASE_URL=http://vllm.internal/v1
VLLM_API_KEY=
RAGAAS_URL=http://ragaas.internal
JIRA_URL=http://jira.internal
JIRA_TOKEN=
GERRIT_URL=http://gerrit.internal
GERRIT_TOKEN=
DB_PATH=./data/connpass.db

# ── 사외 테스트용 (OpenAI) ─────────────────────────────────────────────────────
# OPENAI_API_KEY를 설정하면 프론트엔드에서 gpt-4o / gpt-4o-mini 선택 가능
# Node.js 서버: pi-ai가 OPENAI_API_KEY 환경변수를 자동 감지
# Flask: generate_title이 OpenAI API로 자동 전환
OPENAI_API_KEY=
